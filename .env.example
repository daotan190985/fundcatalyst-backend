# ===== App =====
APP_NAME="FundCatalyst VN"
DEBUG=false

# ===== Database =====
DATABASE_URL=postgresql://fcvn:fcvn@localhost:5432/fundcatalyst
# Docker compose: DATABASE_URL=postgresql://fcvn:fcvn@postgres:5432/fundcatalyst

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== vnstock =====
VNSTOCK_SOURCE=VCI
VNSTOCK_MAX_RETRIES=3

# ===== LLM (cho phần tóm tắt tin tức) =====
# Chọn 1 trong 2 provider. Nếu cả 2 đều trống, dùng fallback rule-based (không có chất lượng cao).
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# LLM_MODEL=  # mặc định: claude-haiku-4-5-20251001 hoặc gpt-4o-mini
# LLM_PROVIDER=auto  # auto|anthropic|openai

# ===== Scheduler =====
ENABLE_SCHEDULER=true
QUOTE_REFRESH_INTERVAL_MIN=5

# ===== CORS =====
# ALLOWED_ORIGINS=["http://localhost:3000","https://fundcatalyst.vn"]
